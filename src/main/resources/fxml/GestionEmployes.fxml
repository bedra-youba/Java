<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.microfinance.views.GestionEmployesViewController">

    <ImageView fitWidth="1200" fitHeight="800"
               preserveRatio="false" opacity="0.35">
        <image><Image url="@../images/billets.jpeg"/></image>
    </ImageView>

    <VBox spacing="16" style="-fx-padding: 25;">

        <HBox alignment="CENTER_LEFT" spacing="15">
            <Button text="⬅  Retour" onAction="#retourDashboard"
                    style="-fx-background-color: rgba(27,94,32,0.8);
                           -fx-text-fill: white; -fx-background-radius: 8;
                           -fx-padding: 8 16; -fx-cursor: hand;"/>
            <VBox HBox.hgrow="ALWAYS"
                  style="-fx-background-color: rgba(27,94,32,0.65);
                         -fx-background-radius: 12; -fx-padding: 15;">
                <Label text="👥  Gestion des Employés"
                       style="-fx-text-fill: white; -fx-font-size: 20;
                              -fx-font-weight: bold;"/>
                <Label text="Ajouter ou supprimer un employé"
                       style="-fx-text-fill: #C8E6C9; -fx-font-size: 12;"/>
            </VBox>

        </HBox>

        <VBox spacing="12"
              style="-fx-background-color: rgba(255,255,255,0.90);
                     -fx-background-radius: 12; -fx-padding: 20;">
            <Label text="Nouvel Employé"
                   style="-fx-font-size: 14; -fx-font-weight: bold;
                          -fx-text-fill: #1B5E20;"/>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="txtNom"      promptText="Nom"       prefWidth="110"
                           style="-fx-background-radius: 8; -fx-padding: 9;"/>
                <TextField fx:id="txtPrenom"   promptText="Prénom"    prefWidth="110"
                           style="-fx-background-radius: 8; -fx-padding: 9;"/>
                <TextField fx:id="txtEmail"    promptText="Email"     prefWidth="140"
                           style="-fx-background-radius: 8; -fx-padding: 9;"/>
                <TextField fx:id="txtTel"      promptText="Téléphone" prefWidth="120"
                           style="-fx-background-radius: 8; -fx-padding: 9;"/>
                <TextField fx:id="txtMatricule" promptText="Matricule" prefWidth="110"
                           style="-fx-background-radius: 8; -fx-padding: 9;"/>
                <TextField fx:id="txtPoste"    promptText="Poste"     prefWidth="110"
                           style="-fx-background-radius: 8; -fx-padding: 9;"/>
                <Button text="✚ Ajouter" onAction="#onAjouterAgent"
                        style="-fx-background-color: #2E7D32; -fx-text-fill: white;
                               -fx-background-radius: 8; -fx-padding: 9 16;
                               -fx-cursor: hand;"/>
                <Button text="✖ Supprimer" onAction="#onSupprimerAgent"
                        style="-fx-background-color: #C62828; -fx-text-fill: white;
                               -fx-background-radius: 8; -fx-padding: 9 16;
                               -fx-cursor: hand;"/>
            </HBox>
            <Label fx:id="lblMessage" style="-fx-font-size: 12;"/>
        </VBox>

        <VBox VBox.vgrow="ALWAYS"
              style="-fx-background-color: rgba(255,255,255,0.90);
                     -fx-background-radius: 12; -fx-padding: 16;">
            <Label text="Liste des Employés"
                   style="-fx-font-size: 14; -fx-font-weight: bold;
                          -fx-text-fill: #1B5E20; -fx-padding: 0 0 10 0;"/>
            <TableView fx:id="tableAgents" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId"        text="ID"        prefWidth="60"/>
                    <TableColumn fx:id="colNom"       text="Nom"       prefWidth="130"/>
                    <TableColumn fx:id="colPrenom"    text="Prénom"    prefWidth="130"/>
                    <TableColumn fx:id="colEmail"     text="Email"     prefWidth="170"/>
                    <TableColumn fx:id="colMatricule" text="Matricule" prefWidth="110"/>
                    <TableColumn fx:id="colPoste"     text="Poste"     prefWidth="120"/>
                </columns>
            </TableView>
        </VBox>
    </VBox>
</StackPane>