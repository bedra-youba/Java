<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.microfinance.views.DashboardAgentViewController">

    <ImageView fitWidth="1200" fitHeight="800"
               preserveRatio="false" opacity="0.35">
        <image><Image url="@../images/billets.jpeg"/></image>
    </ImageView>

    <HBox>
        <VBox spacing="0"
              style="-fx-background-color: rgba(27,94,32,0.75);
                     -fx-min-width: 220; -fx-pref-width: 220;">
            <padding><Insets top="20" bottom="20"/></padding>

            <VBox alignment="CENTER" spacing="6"
                  style="-fx-padding: 0 10 20 10;">
                <ImageView fitWidth="70" fitHeight="47" preserveRatio="true">
                    <image><Image url="@../images/drapeau.jpg"/></image>
                </ImageView>
                <Label text="MicroFinance"
                       style="-fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold;"/>
                <Label text="Espace Agent"
                       style="-fx-text-fill: #A5D6A7; -fx-font-size: 13;"/>
            </VBox>

            <Separator style="-fx-background-color: rgba(255,255,255,0.3);"/>

            <VBox spacing="4" style="-fx-padding: 15 10 0 10;">
                <Button text="🏠  Accueil"
                        style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-alignment: CENTER-LEFT; -fx-pref-width: 195; -fx-padding: 10 15; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-size: 13;"/>
                <Button text="👤  Gérer Clients" onAction="#ouvrirGestionClients"
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER-LEFT; -fx-pref-width: 195; -fx-padding: 10 15; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-size: 13;"/>
                <Button text="💳  Comptes Épargne" onAction="#ouvrirCompteEpargne"
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER-LEFT; -fx-pref-width: 195; -fx-padding: 10 15; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-size: 13;"/>
                <Button text="🛒  Demandes Achat" onAction="#ouvrirDemandesAchat"
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER-LEFT; -fx-pref-width: 195; -fx-padding: 10 15; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-size: 13;"/>
                <Button text="🏭  Fournisseurs" onAction="#ouvrirFournisseurs"
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER-LEFT; -fx-pref-width: 195; -fx-padding: 10 15; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-size: 13;"/>
            </VBox>

            <VBox VBox.vgrow="ALWAYS" alignment="BOTTOM_CENTER"
                  style="-fx-padding: 0 10 10 10;">
                <Button text="⬅  Déconnexion"
                        style="-fx-background-color: transparent; -fx-text-fill: #EF9A9A; -fx-alignment: CENTER-LEFT; -fx-pref-width: 195; -fx-padding: 10 15; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-size: 13;"/>
            </VBox>
        </VBox>

        <VBox spacing="20" HBox.hgrow="ALWAYS">
            <padding><Insets top="20" right="25" bottom="20" left="25"/></padding>

            <HBox alignment="CENTER_LEFT" spacing="10">
                <VBox HBox.hgrow="ALWAYS"
                      style="-fx-background-color: rgba(27,94,32,0.65); -fx-background-radius: 12; -fx-padding: 18;">
                    <Label text="Bienvenue, Agent 👋"
                           style="-fx-text-fill: #A5D6A7; -fx-font-size: 13;"/>
                    <Label text="Tableau de bord — Agent"
                           style="-fx-text-fill: white; -fx-font-size: 22; -fx-font-weight: bold;"/>
                    <Label text="Gérer les clients et les opérations"
                           style="-fx-text-fill: #C8E6C9; -fx-font-size: 12;"/>
                </VBox>
                <VBox alignment="CENTER" spacing="6"
                      style="-fx-background-color: rgba(27,94,32,0.65); -fx-background-radius: 12; -fx-padding: 18;">
                    <ImageView fitWidth="90" fitHeight="60" preserveRatio="true">
                        <image><Image url="@../images/drapeau.jpg"/></image>
                    </ImageView>
                    <Label text="Mauritanie"
                           style="-fx-text-fill: white; -fx-font-size: 12;"/>
                </VBox>
            </HBox>

            <HBox spacing="16">
                <VBox style="-fx-background-color: rgba(255,255,255,0.82); -fx-background-radius: 12; -fx-padding: 18; -fx-border-color: #2E7D32; -fx-border-width: 0 0 0 5; -fx-border-radius: 12; -fx-cursor: hand;"
                      HBox.hgrow="ALWAYS" onMouseClicked="#ouvrirGestionClients">
                    <Label text="👤  Clients"
                           style="-fx-font-size: 12; -fx-text-fill: #555;"/>
                    <Label fx:id="lblNombreClients" text="0"
                           style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #1B5E20;"/>
                    <Label text="Cliquer pour gérer les clients"
                           style="-fx-font-size: 10; -fx-text-fill: #888;"/>
                </VBox>

                <VBox style="-fx-background-color: rgba(255,255,255,0.82); -fx-background-radius: 12; -fx-padding: 18; -fx-border-color: #2E7D32; -fx-border-width: 0 0 0 5; -fx-border-radius: 12; -fx-cursor: hand;"
                      HBox.hgrow="ALWAYS" onMouseClicked="#ouvrirCompteEpargne">
                    <Label text="💳  Comptes Épargne"
                           style="-fx-font-size: 12; -fx-text-fill: #555;"/>
                    <Label fx:id="lblNombreComptes" text="0"
                           style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #1B5E20;"/>
                    <Label text="Cliquer pour gérer les comptes"
                           style="-fx-font-size: 10; -fx-text-fill: #888;"/>
                </VBox>

                <VBox style="-fx-background-color: rgba(255,255,255,0.82); -fx-background-radius: 12; -fx-padding: 18; -fx-border-color: #2E7D32; -fx-border-width: 0 0 0 5; -fx-border-radius: 12; -fx-cursor: hand;"
                      HBox.hgrow="ALWAYS" onMouseClicked="#ouvrirDemandesAchat">
                    <Label text="🛒  Demandes Achat"
                           style="-fx-font-size: 12; -fx-text-fill: #555;"/>
                    <Label fx:id="lblNombreDemandes" text="0"
                           style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #1B5E20;"/>
                    <Label text="Cliquer pour voir les demandes"
                           style="-fx-font-size: 10; -fx-text-fill: #888;"/>
                </VBox>

                <VBox style="-fx-background-color: rgba(255,255,255,0.82); -fx-background-radius: 12; -fx-padding: 18; -fx-border-color: #2E7D32; -fx-border-width: 0 0 0 5; -fx-border-radius: 12; -fx-cursor: hand;"
                      HBox.hgrow="ALWAYS" onMouseClicked="#ouvrirFournisseurs">
                    <Label text="🏭  Fournisseurs"
                           style="-fx-font-size: 12; -fx-text-fill: #555;"/>
                    <Label fx:id="lblNombreFournisseurs" text="0"
                           style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #1B5E20;"/>
                    <Label text="Cliquer pour consulter"
                           style="-fx-font-size: 10; -fx-text-fill: #888;"/>
                </VBox>
            </HBox>

            <VBox spacing="12"
                  style="-fx-background-color: rgba(255,255,255,0.82); -fx-background-radius: 12; -fx-padding: 20;">
                <Label text="Actions rapides"
                       style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #1B5E20;"/>
                <HBox spacing="12">
                    <Button text="👤  Gérer Clients" onAction="#ouvrirGestionClients"
                            style="-fx-background-color: #1B5E20; -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 12 20; -fx-cursor: hand; -fx-font-size: 13;"/>
                    <Button text="💳  Comptes Épargne" onAction="#ouvrirCompteEpargne"
                            style="-fx-background-color: #2E7D32; -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 12 20; -fx-cursor: hand; -fx-font-size: 13;"/>
                    <Button text="🛒  Demandes Achat" onAction="#ouvrirDemandesAchat"
                            style="-fx-background-color: #388E3C; -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 12 20; -fx-cursor: hand; -fx-font-size: 13;"/>
                    <Button text="🏭  Fournisseurs" onAction="#ouvrirFournisseurs"
                            style="-fx-background-color: #43A047; -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 12 20; -fx-cursor: hand; -fx-font-size: 13;"/>
                </HBox>
            </VBox>

        </VBox>
    </HBox>
</StackPane>