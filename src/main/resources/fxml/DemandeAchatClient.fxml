<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.microfinance.views.DemandeAchatClientViewController">

    <ImageView fitWidth="1200" fitHeight="800"
               preserveRatio="false" opacity="0.35">
        <image><Image url="@../images/billets.jpeg"/></image>
    </ImageView>

    <VBox spacing="16" style="-fx-padding: 25;">
        <HBox alignment="CENTER_LEFT" spacing="15">
            <Button text="⬅  Retour" onAction="#retourDashboard"
                    style="-fx-background-color: rgba(27,94,32,0.8); -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 8 16; -fx-cursor: hand;"/>
            <VBox HBox.hgrow="ALWAYS"
                  style="-fx-background-color: rgba(27,94,32,0.65); -fx-background-radius: 12; -fx-padding: 15;">
                <Label text="🛒  Faire une Demande d'Achat"
                       style="-fx-text-fill: white; -fx-font-size: 20; -fx-font-weight: bold;"/>
                <Label text="Soumettre une demande de financement Mourabaha"
                       style="-fx-text-fill: #A5D6A7; -fx-font-size: 12;"/>
            </VBox>
            <ImageView fitWidth="80" fitHeight="53" preserveRatio="true">
                <image><Image url="@../images/drapeau.jpg"/></image>
            </ImageView>
        </HBox>

        <!-- Formulaire — sans ID client -->
        <VBox spacing="12"
              style="-fx-background-color: rgba(255,255,255,0.90); -fx-background-radius: 12; -fx-padding: 20;">
            <Label text="Nouvelle Demande"
                   style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #1B5E20;"/>
            <HBox spacing="10">
                <TextField fx:id="txtDescriptionClient"
                           promptText="Description du bien souhaité" prefWidth="380"
                           style="-fx-background-radius: 8; -fx-padding: 9;"/>
                <TextField fx:id="txtPrixEstimeClient"
                           promptText="Prix estimé (MRU)" prefWidth="180"
                           style="-fx-background-radius: 8; -fx-padding: 9;"/>
                <Button text="✚ Soumettre" onAction="#onSoumettreDemandeClient"
                        style="-fx-background-color: #1B5E20; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 9 16; -fx-cursor: hand;"/>
            </HBox>
            <Label fx:id="lblMessageDemandeClient" style="-fx-font-size: 12;"/>
        </VBox>

        <!-- Mes demandes uniquement -->
        <VBox VBox.vgrow="ALWAYS"
              style="-fx-background-color: rgba(255,255,255,0.90); -fx-background-radius: 12; -fx-padding: 16;">
            <Label text="Mes Demandes"
                   style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #1B5E20; -fx-padding: 0 0 10 0;"/>
            <TableView fx:id="tableMesDemandes" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colIdDem" text="N° Demande" prefWidth="100"/>
                    <TableColumn fx:id="colDateDem" text="Date"        prefWidth="130"/>
                    <TableColumn fx:id="colDescDem" text="Description" prefWidth="280"/>
                    <TableColumn fx:id="colPrixDem" text="Prix (MRU)"  prefWidth="120"/>
                    <TableColumn fx:id="colStatDem" text="Statut"      prefWidth="120"/>
                </columns>
            </TableView>
        </VBox>
    </VBox>
</StackPane>
