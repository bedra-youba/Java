<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.microfinance.views.GestionClientsViewController">

    <ImageView fitWidth="1200" fitHeight="800"
               preserveRatio="false" opacity="0.35">
        <image><Image url="@../images/billets.jpeg"/></image>
    </ImageView>

    <VBox spacing="16" style="-fx-padding: 25;">

        <HBox alignment="CENTER_LEFT" spacing="15">
            <Button text="⬅  Retour" onAction="#retourDashboard"
                    style="-fx-background-color: rgba(27,94,32,0.8);
                           -fx-text-fill: white; -fx-background-radius: 8;
                           -fx-padding: 8 16; -fx-cursor: hand;"/>
            <VBox HBox.hgrow="ALWAYS"
                  style="-fx-background-color: rgba(27,94,32,0.65);
                         -fx-background-radius: 12; -fx-padding: 15;">
                <Label text="👤  Gestion des Clients"
                       style="-fx-text-fill: white; -fx-font-size: 20;
                              -fx-font-weight: bold;"/>
                <Label text="Ajouter ou modifier un client"
                       style="-fx-text-fill: #A5D6A7; -fx-font-size: 12;"/>
            </VBox>
            <ImageView fitWidth="80" fitHeight="53" preserveRatio="true">
                <image><Image url="@../images/drapeau.jpg"/></image>
            </ImageView>
        </HBox>

        <!-- Formulaire -->
        <VBox spacing="12"
              style="-fx-background-color: rgba(255,255,255,0.90);
                     -fx-background-radius: 12; -fx-padding: 20;">
            <Label text="Nouveau Client"
                   style="-fx-font-size: 14; -fx-font-weight: bold;
                          -fx-text-fill: #1B5E20;"/>
            <HBox spacing="10">
                <TextField fx:id="txtNom" promptText="Nom complet" prefWidth="140"
                           style="-fx-background-radius: 8; -fx-padding: 9;"/>
                <TextField fx:id="txtNNI" promptText="NNI (10 chiffres)" prefWidth="130"
                           style="-fx-background-radius: 8; -fx-padding: 9;"/>
                <TextField fx:id="txtTelephone" promptText="Téléphone (8 chiffres)" prefWidth="150"
                           style="-fx-background-radius: 8; -fx-padding: 9;"/>
                <TextField fx:id="txtAdresse" promptText="Adresse" prefWidth="140"
                           style="-fx-background-radius: 8; -fx-padding: 9;"/>
                <TextField fx:id="txtProfession" promptText="Profession" prefWidth="130"
                           style="-fx-background-radius: 8; -fx-padding: 9;"/>
                <TextField fx:id="txtRevenu" promptText="Revenu (MRU)" prefWidth="120"
                           style="-fx-background-radius: 8; -fx-padding: 9;"/>
            </HBox>
            <HBox spacing="10">
                <Button text="✚ Ajouter" onAction="#onAjouterClient"
                        style="-fx-background-color: #1B5E20; -fx-text-fill: white;
                               -fx-background-radius: 8; -fx-padding: 9 16;
                               -fx-cursor: hand;"/>
                <Button text="✎ Modifier" onAction="#onModifierClient"
                        style="-fx-background-color: #388E3C; -fx-text-fill: white;
                               -fx-background-radius: 8; -fx-padding: 9 16;
                               -fx-cursor: hand;"/>
            </HBox>
            <Label fx:id="lblMessage" style="-fx-font-size: 12;"/>
        </VBox>

        <!-- Table -->
        <VBox VBox.vgrow="ALWAYS"
              style="-fx-background-color: rgba(255,255,255,0.90);
                     -fx-background-radius: 12; -fx-padding: 16;">
            <Label text="Liste des Clients"
                   style="-fx-font-size: 14; -fx-font-weight: bold;
                          -fx-text-fill: #1B5E20; -fx-padding: 0 0 10 0;"/>
            <TableView fx:id="tableClients" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId"         text="ID"         prefWidth="55"/>
                    <TableColumn fx:id="colNom"        text="Nom"        prefWidth="140"/>
                    <TableColumn fx:id="colNNI"        text="NNI"        prefWidth="120"/>
                    <TableColumn fx:id="colTelephone"  text="Téléphone"  prefWidth="120"/>
                    <TableColumn fx:id="colAdresse"    text="Adresse"    prefWidth="150"/>
                    <TableColumn fx:id="colProfession" text="Profession" prefWidth="130"/>
                    <TableColumn fx:id="colRevenu"     text="Revenu"     prefWidth="110"/>
                    <TableColumn fx:id="colStatut"     text="Statut"     prefWidth="100"/>
                </columns>
            </TableView>
        </VBox>
    </VBox>
</StackPane>