<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.microfinance.views.GestionAgencesViewController">

    <ImageView fitWidth="1200" fitHeight="800"
               preserveRatio="false" opacity="0.35">
        <image><Image url="@../images/billets.jpeg"/></image>
    </ImageView>

    <VBox spacing="16" style="-fx-padding: 25;">

        <!-- En-tête avec retour -->
        <HBox alignment="CENTER_LEFT" spacing="15">
            <Button text="⬅  Retour" onAction="#retourDashboard"
                    style="-fx-background-color: rgba(27,94,32,0.8);
                           -fx-text-fill: white; -fx-background-radius: 8;
                           -fx-padding: 8 16; -fx-cursor: hand;"/>
            <VBox HBox.hgrow="ALWAYS"
                  style="-fx-background-color: rgba(27,94,32,0.65);
                         -fx-background-radius: 12; -fx-padding: 15;">
                <Label text="🏦  Gestion des Agences"
                       style="-fx-text-fill: white; -fx-font-size: 20;
                              -fx-font-weight: bold;"/>
                <Label text="Ajouter, modifier ou supprimer une agence"
                       style="-fx-text-fill: #C8E6C9; -fx-font-size: 12;"/>
            </VBox>

        </HBox>

        <!-- Formulaire -->
        <VBox spacing="12"
              style="-fx-background-color: rgba(255,255,255,0.90);
                     -fx-background-radius: 12; -fx-padding: 20;">
            <Label text="Nouvelle Agence"
                   style="-fx-font-size: 14; -fx-font-weight: bold;
                          -fx-text-fill: #1B5E20;"/>
            <HBox spacing="12" alignment="CENTER_LEFT">
                <TextField fx:id="txtNomAgence" promptText="Nom agence"
                           prefWidth="160"
                           style="-fx-background-radius: 8; -fx-padding: 9;"/>
                <TextField fx:id="txtVilleAgence" promptText="Ville"
                           prefWidth="130"
                           style="-fx-background-radius: 8; -fx-padding: 9;"/>
                <TextField fx:id="txtTelAgence" promptText="Téléphone"
                           prefWidth="140"
                           style="-fx-background-radius: 8; -fx-padding: 9;"/>
                <TextField fx:id="txtCapitalAgence" promptText="Capital (MRU)"
                           prefWidth="140"
                           style="-fx-background-radius: 8; -fx-padding: 9;"/>
                <Button text="✚ Ajouter" onAction="#onAjouterAgence"
                        style="-fx-background-color: #2E7D32; -fx-text-fill: white;
                               -fx-background-radius: 8; -fx-padding: 9 16;
                               -fx-cursor: hand; -fx-font-size: 13;"/>
                <Button text="✎ Modifier" onAction="#onModifierAgence"
                        style="-fx-background-color: #F57C00; -fx-text-fill: white;
                               -fx-background-radius: 8; -fx-padding: 9 16;
                               -fx-cursor: hand; -fx-font-size: 13;"/>
                <Button text="✖ Supprimer" onAction="#onSupprimerAgence"
                        style="-fx-background-color: #C62828; -fx-text-fill: white;
                               -fx-background-radius: 8; -fx-padding: 9 16;
                               -fx-cursor: hand; -fx-font-size: 13;"/>
            </HBox>
            <Label fx:id="lblMessage" style="-fx-font-size: 12;"/>
        </VBox>

        <!-- Table -->
        <VBox VBox.vgrow="ALWAYS"
              style="-fx-background-color: rgba(255,255,255,0.90);
                     -fx-background-radius: 12; -fx-padding: 16;">
            <Label text="Liste des Agences"
                   style="-fx-font-size: 14; -fx-font-weight: bold;
                          -fx-text-fill: #1B5E20; -fx-padding: 0 0 10 0;"/>
            <TableView fx:id="tableAgences" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId"      text="ID"           prefWidth="60"/>
                    <TableColumn fx:id="colNom"     text="Nom Agence"   prefWidth="200"/>
                    <TableColumn fx:id="colVille"   text="Ville"        prefWidth="150"/>
                    <TableColumn fx:id="colTel"     text="Téléphone"    prefWidth="150"/>
                    <TableColumn fx:id="colCapital" text="Capital (MRU)" prefWidth="150"/>
                </columns>
            </TableView>
        </VBox>
    </VBox>
</StackPane>